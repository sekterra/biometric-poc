<?xml version="1.0" encoding="utf-8"?>
<!--
  ※ 이 파일은 현재 사용되지 않습니다.
  MainActivity가 WebView(assets/main.html) 기반으로 전환되었습니다.
  원복 시 MainActivity.java에서 setContentView(R.layout.activity_main)으로 교체하세요.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/main_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/main_entry_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/main_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/main_checking_status"
            android:textSize="14sp" />

        <ProgressBar
            android:id="@+id/main_progress"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:visibility="visible" />

        <TextView
            android:id="@+id/main_status_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textSize="14sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/main_locked_user_id"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/main_hint_user_id"
            android:inputType="text"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:visibility="gone"
            tools:visibility="visible" />

        <EditText
            android:id="@+id/main_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/main_hint_password"
            android:inputType="textPassword"
            android:textSize="14sp"
            android:padding="12dp"
            android:background="@android:drawable/edit_text"
            android:visibility="gone"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/main_login_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/main_button_login"
            android:visibility="gone"
            app:cornerRadius="8dp"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUserChange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:text="@string/user_change_dialog_title"
            android:textSize="13sp"
            android:textColor="#888888"
            android:layout_gravity="center"
            android:layout_marginTop="8dp"
            android:visibility="gone" />
    </LinearLayout>
</ScrollView>
