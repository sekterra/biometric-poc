<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.biometric.poc.demo"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="23"
        android:targetSdkVersion="33" />

    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.INTERNET" />

    <uses-feature
        android:name="android.hardware.biometrics.face"
        android:required="false" />

    <!-- suppress DeprecatedClassUsageInspection -->
    <uses-permission android:name="android.permission.USE_FINGERPRINT" />

    <application
        android:name="com.biometric.poc.demo.BiometricApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.BiometricDemo"
        android:usesCleartextTraffic="true" >
        <activity
            android:name="com.biometric.poc.demo.MainActivity"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name="com.biometric.poc.demo.RegisterActivity"
            android:exported="false" />
        <activity
            android:name="com.biometric.poc.demo.LoginActivity"
            android:exported="false" />
        <activity
            android:name="com.biometric.poc.demo.MainAfterLoginActivity"
            android:exported="false" />
    </application>

</manifest>